{
  "name": "reasoningbank",
  "version": "0.1.0",
  "description": "Shared learning pool for AI agents — every run makes all future runs smarter",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": "./dist/server.js",
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js"
    }
  },
  "bin": {
    "reasoningbank": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai-agents", "agent-memory", "multi-agent", "llm", "reasoning", "trajectory", "evals"],
  "author": "CyberRanger93",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
